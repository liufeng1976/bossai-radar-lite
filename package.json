{
  "name": "bossai-radar-lite",
  "version": "0.7.0",
  "private": true,
  "description": "BossAI Radar Lite - source-available non-commercial overseas business opportunity radar",
  "type": "module",
  "bin": {
    "bossai-radar-install": "scripts/agent-bootstrap.mjs"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/src/server.js",
    "mcp": "node dist/src/mcp-server.js",
    "mcp:dev": "tsx src/mcp-server.ts",
    "agent": "node dist/src/agent-cli.js",
    "agent:dev": "tsx src/agent-cli.ts",
    "skill:install": "node scripts/install-agent-skill.mjs",
    "agent:install": "node scripts/agent-bootstrap.mjs",
    "service:start": "node scripts/radar-service.mjs start",
    "service:stop": "node scripts/radar-service.mjs stop",
    "service:restart": "node scripts/radar-service.mjs restart",
    "service:status": "node scripts/radar-service.mjs status",
    "build": "tsc -p tsconfig.json && node scripts/copy-public.mjs",
    "test": "tsx --test tests/**/*.test.ts",
    "check:frontend": "node --check public/app.js && node --check public/commercial.js && node --check public/leads.js && node --check public/i18n.js",
    "check:i18n": "node scripts/i18n-check.mjs",
    "check": "npm run test && npm run check:frontend && npm run check:i18n && npm run build",
    "release:check": "npm run check && node scripts/release-check.mjs",
    "package:release": "npm run release:check && node scripts/package-release.mjs"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
