{
  "name": "bossai-radar-lite",
  "version": "0.2.0",
  "private": true,
  "description": "BossAI Radar Lite - source-available non-commercial overseas business opportunity radar",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/src/server.js",
    "build": "tsc -p tsconfig.json && node scripts/copy-public.mjs",
    "test": "tsx --test tests/**/*.test.ts",
    "check:frontend": "node --check public/app.js",
    "check": "npm run test && npm run check:frontend && npm run build",
    "release:check": "npm run check && node scripts/release-check.mjs"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
